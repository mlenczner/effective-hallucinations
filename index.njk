<section class="home-section bookmarks-section">
  <h2 class="section-heading">Bookmarks <a href="https://hypothes.is/users/mlenc" class="bookmarks-all" target="_blank" rel="noopener">all →</a></h2>
  <ul class="bookmark-list" id="hyp-bookmarks">
    <li class="bookmark-loading">Loading…</li>
  </ul>
</section>

<script>
fetch('https://api.hypothes.is/api/search?user=acct:mlenc@hypothes.is&limit=50&sort=created&order=desc')
  .then(function(r) { return r.json(); })
  .then(function(data) {
    var seen = {};
    var links = [];
    for (var i = 0; i < data.rows.length; i++) {
      var row = data.rows[i];
      var url = row.uri;
      if (!seen[url] && links.length < 5) {
        seen[url] = true;
        var title = (row.document && row.document.title && row.document.title[0]) ? row.document.title[0] : url;
        links.push({ url: url, title: title, tags: row.tags || [] });
      }
    }
    var list = document.getElementById('hyp-bookmarks');
    if (links.length === 0) {
      list.innerHTML = '<li class="bookmark-loading">No bookmarks found.</li>';
      return;
    }
    list.innerHTML = links.map(function(link) {
      var tagsHtml = link.tags.length
        ? '<span class="bookmark-tags">' + link.tags.map(function(t) { return '<span class="bookmark-tag">' + t + '</span>'; }).join('') + '</span>'
        : '';
      return '<li class="bookmark-item"><a href="' + link.url + '" class="bookmark-title" target="_blank" rel="noopener">' + link.title + '</a>' + tagsHtml + '</li>';
    }).join('');
  })
  .catch(function() {
    document.getElementById('hyp-bookmarks').innerHTML = '<li class="bookmark-loading">Could not load bookmarks.</li>';
  });
</script>
