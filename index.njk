<section class="home-section">
  <h2 class="section-heading">Writing</h2>
  <ul class="post-list">
    {% for post in collections.writing %}
    <li>
      <p class="post-meta">{{ post.date | readableDate }}</p>
      <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      {% if post.data.description %}<p class="post-excerpt">{{ post.data.description }}</p>{% endif %}
    </li>
    {% endfor %}
  </ul>
</section>
