<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title and title != 'Effective Hallucinations' %}{{ title }} &mdash; {% endif %}Effective Hallucinations</title>
  <meta name="description" content="{{ description or 'Conversations with AI about nonprofits, philanthropy, and the social sector.' }}">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="aiblog">
<script>
(function() {
  if (sessionStorage.getItem('auth') !== 'yes') {
    var pwd = prompt('Password:');
    if (pwd !== 'canada') {
      document.body.innerHTML = '<p style="font-family:sans-serif;padding:2rem;">Access denied.</p>';
      return;
    }
    sessionStorage.setItem('auth', 'yes');
  }
})();
</script>

  <header class="blog-header">
    <div class="blog-header-inner">
      <a class="blog-title" href="/AIblog/">Effective <span>Hallucinations</span></a>
      <p class="blog-tagline">Conversations with AI about nonprofits, philanthropy, and the social sector.</p>
      <nav class="blog-nav">
        <a href="/">← michaellenczner.com</a>
        <a href="/AIblog/">Posts</a>
      </nav>
    </div>
  </header>

  <main class="blog-main">
    {{ content | safe }}
  </main>

  <footer class="blog-footer">
    <p>Effective Hallucinations &mdash; <a href="mailto:mlenczner@gmail.com" style="color:inherit">Mike Lenczner</a></p>
  </footer>

</body>
</html>
