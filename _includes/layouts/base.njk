<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} &mdash; {% endif %}Michael Lenczner</title>
  <meta name="description" content="{{ description or 'Michael Lenczner — technology, data, and social change.' }}">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="{{ bodyClass or '' }}">
<script>
(function() {
  if (sessionStorage.getItem('auth') !== 'yes') {
    var pwd = prompt('Password:');
    if (pwd !== 'canada') {
      document.body.innerHTML = '<p style="font-family:sans-serif;padding:2rem;">Access denied.</p>';
      return;
    }
    sessionStorage.setItem('auth', 'yes');
  }
})();
</script>

  <header class="site-header">
    <a class="site-title" href="/">Michael Lenczner</a>
    <nav>
      <a href="/">Home</a>
      <a href="/AIblog/">Effective Hallucinations</a>
      <a href="/AIblog/about/">About</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>Michael Lenczner &mdash; <a href="mailto:mlenczner@gmail.com" style="color:inherit">mlenczner@gmail.com</a></p>
  </footer>

</body>
</html>
