---
layout: layouts/aiblog-base.njk
title: "Effective Hallucinations"
permalink: /AIblog/
---

<ul class="post-list">
  {% for post in collections.aiblog %}
  <li>
    <p class="post-meta">{{ post.date | readableDate }}</p>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.description %}<p class="post-excerpt">{{ post.data.description }}</p>{% endif %}
  </li>
  {% endfor %}
</ul>
